{
  "manifest_version": 3,
  "name": "CRO Audit by Optimise Digital",
  "version": "1.0.0",
  "description": "One-click conversion rate audit for any webpage. See what's helping and hurting your conversions.",
  "icons": {
    "16": "public/icons/icon-16.png",
    "32": "public/icons/icon-32.png",
    "48": "public/icons/icon-48.png",
    "128": "public/icons/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "public/icons/icon-16.png",
      "32": "public/icons/icon-32.png",
      "48": "public/icons/icon-48.png",
      "128": "public/icons/icon-128.png"
    },
    "default_title": "CRO Audit by Optimise Digital"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.optimisedigital.online/*",
    "https://website-growth-tools-production.up.railway.app/*"
  ]
}
